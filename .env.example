# GitHub OAuth app client ID (required for GitHub sync)
# Register an OAuth app at github.com/settings/developers
# Use Device Flow — no client_secret needed in the browser
VITE_GITHUB_CLIENT_ID=replace_me

# Cloudflare Worker URL that proxies GitHub's OAuth endpoints to add CORS headers.
# GitHub's device/code and access_token endpoints don't return Access-Control-Allow-Origin,
# so direct browser fetch() calls are blocked. Deploy the worker from cloudflare/github-auth-proxy/
# and set this to the worker URL (e.g. https://family-prepared-github-auth.<subdomain>.workers.dev).
# Required for the deployed app. Can be omitted for local dev (auth won't work in browser without it).
VITE_GITHUB_PROXY_URL=replace_me

# Canonical template repo users copy to get started (org/repo format)
VITE_TEMPLATE_REPO=family-prepared/family-prepared-template

# Community pack registry JSON index URL
VITE_REGISTRY_URL=https://raw.githubusercontent.com/family-prepared/registry/main/index.json
